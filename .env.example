# Apollos server runtime
APP_ENV=development

# Gemini
ENABLE_GEMINI_LIVE=1
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENDPOINT_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_LIVE_ENDPOINT_BASE=wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1beta.GenerativeService.BidiGenerateContent
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Firestore persistence
USE_FIRESTORE=0
FIRESTORE_REQUIRED=0
GOOGLE_CLOUD_PROJECT=
# Optional direct token; leave empty to use metadata token on Cloud Run
FIRESTORE_BEARER_TOKEN=
SESSION_PERSIST_MIN_INTERVAL_S=1.5

# Auth / CORS
WS_AUTH_MODE=oidc_broker
WS_AUTH_TOKEN=
OIDC_REQUIRE_STRICT=0
OIDC_ALLOW_INSECURE_DEV_TOKENS=0
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_ALGORITHMS=RS256,ES256
OIDC_LEEWAY_SECONDS=30
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WS_MAX_INBOUND_BYTES=524288
HTTP_MAX_BODY_BYTES=2097152
SINGLE_INSTANCE_ONLY=1
ENABLE_DEV_ENDPOINTS=0
DEV_ENDPOINT_TOKEN=

# Human fallback + Twilio
PUBLIC_HELP_BASE=https://example.com/help
HELP_TICKET_TTL_S=300
HELP_VIEWER_TTL_S=300
TWILIO_ACCOUNT_SID=
TWILIO_VIDEO_API_KEY_SID=
TWILIO_VIDEO_API_KEY_SECRET=
TWILIO_REQUIRED=0
TWILIO_VIDEO_ROOM_PREFIX=apollos-help
TWILIO_VIDEO_TOKEN_TTL_SECONDS=900

# ONNX model path for apollos-core (ml feature)
APOLLOS_DEPTH_ONNX_MODEL=
