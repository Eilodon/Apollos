# Frontend
VITE_BACKEND_WS_BASE=ws://localhost:8000/ws
VITE_API_BASE=http://localhost:8000
VITE_DEPTH_MODEL_URL=/models/depth_anything_v2_small_fp16.tflite

# Backend
GOOGLE_CLOUD_PROJECT=your-project-id
GEMINI_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_MODEL_FALLBACKS=
ENABLE_GEMINI_LIVE=1
GEMINI_USE_VERTEX=0
GOOGLE_API_KEY=your-google-ai-api-key
GOOGLE_CLOUD_LOCATION=us-central1
USE_FIRESTORE=0
ENABLE_MAPS_GROUNDING=0
HAZARD_CONFIRMATION_FRAMES=1
EDGE_HAZARD_SUPPRESS_SECONDS=2.5
PUBLIC_HELP_BASE=https://example.com/help
APP_ENV=development
WS_AUTH_MODE=shared_token
WS_AUTH_TOKEN=change-me
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_ALGORITHMS=RS256,ES256
OIDC_LEEWAY_SECONDS=30
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENABLE_DEV_ENDPOINTS=0
DEV_ENDPOINT_TOKEN=
