# Backend Environment Variables Template
# Copy this file to .env and fill in the values

# Required: Gemini API Key or Google Cloud credentials
GEMINI_API_KEY="your_api_key_here"

# Model Selection
GEMINI_MODEL="gemini-live-2.5-flash-native-audio"
GEMINI_MODEL_FALLBACKS=""
ENABLE_GEMINI_LIVE="1"

# Database/Logging Configuration
USE_FIRESTORE="0"
GOOGLE_CLOUD_PROJECT="your_gcp_project_id" # Required if USE_FIRESTORE="1" or GEMINI_USE_VERTEX="1"

# Safety Pipeline Configuration
HAZARD_CONFIRMATION_FRAMES="1"
HAZARD_CONFIRMATION_TIMEOUT_S="3.0"
EDGE_HAZARD_SUPPRESS_SECONDS="2.5"
SESSION_PERSIST_MIN_INTERVAL_S="1.5"
SENSOR_HEALTH_DEGRADED_THRESHOLD="0.55"
LOCALIZATION_UNCERTAINTY_DEGRADED_M="45"
MAX_WS_MESSAGE_BYTES="1250000"
MAX_FRAME_B64_CHARS="1800000"
MAX_AUDIO_CHUNK_B64_CHARS="240000"
MAX_USER_COMMAND_CHARS="400"
MAX_SENSOR_HEALTH_FLAGS="8"

# System Configuration
APP_ENV="development" # set to "production" on deployed environments
LOG_LEVEL="INFO"
PUBLIC_HELP_BASE="https://your-frontend-domain.com/help"
WS_AUTH_MODE="shared_token" # shared_token | oidc | disabled
WS_AUTH_TOKEN="" # REQUIRED in production when WS_AUTH_MODE=shared_token
OIDC_ISSUER="" # REQUIRED when WS_AUTH_MODE=oidc (e.g. https://accounts.google.com)
OIDC_AUDIENCE="" # REQUIRED when WS_AUTH_MODE=oidc (comma-separated if multiple)
OIDC_JWKS_URL="" # optional override, auto-derived from OIDC_ISSUER when empty
OIDC_ALGORITHMS="RS256,ES256"
OIDC_LEEWAY_SECONDS="30"
OIDC_BROKER_ENABLED="1" # issues short-lived ws tickets via secure cookie session
OIDC_BROKER_SIGNING_KEY="" # REQUIRED in production
OIDC_BROKER_WS_TTL_SECONDS="90"
OIDC_BROKER_SESSION_TTL_SECONDS="3600"
OIDC_BROKER_COOKIE_NAME="apollos_broker_session"
OIDC_BROKER_COOKIE_SECURE="1"
OIDC_BROKER_COOKIE_SAMESITE="lax" # lax | strict | none
OIDC_BROKER_COOKIE_DOMAIN=""
OIDC_BROKER_COOKIE_PATH="/"
WS_ALLOW_QUERY_TOKEN="" # empty => auto (enabled for local dev, disabled in production)
CORS_ALLOW_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
ENABLE_DEV_ENDPOINTS="0" # Keep disabled in production
DEV_ENDPOINT_TOKEN="" # Required if ENABLE_DEV_ENDPOINTS="1" on shared environments

# Human fallback live assist (secure helper link + short-lived viewer token)
HUMAN_FALLBACK_ENABLED="1"
HUMAN_HELP_SIGNING_KEY="" # REQUIRED in production when HUMAN_FALLBACK_ENABLED=1
HUMAN_HELP_ISSUER="apollos-human-help"
HUMAN_HELP_TICKET_TTL_SECONDS="300"
HUMAN_HELP_VIEWER_TOKEN_TTL_SECONDS="900"
HELP_FRAME_MIN_INTERVAL_MS="350"
EMERGENCY_CONTACTS="" # comma-separated E.164 numbers, e.g. +84901234567,+14155551234
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
HELP_RTC_PROVIDER="twilio" # twilio | relay
TWILIO_VIDEO_API_KEY_SID=""
TWILIO_VIDEO_API_KEY_SECRET=""
TWILIO_VIDEO_ROOM_PREFIX="apollos-help"
TWILIO_VIDEO_TOKEN_TTL_SECONDS="900"
