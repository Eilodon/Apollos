# Backend Environment Variables Template
# Copy this file to .env and fill in the values

# Required: Gemini API Key or Google Cloud credentials
GEMINI_API_KEY="your_api_key_here"

# Model Selection
GEMINI_MODEL="gemini-live-2.5-flash-native-audio"
GEMINI_MODEL_FALLBACKS=""
ENABLE_GEMINI_LIVE="1"

# Database/Logging Configuration
USE_FIRESTORE="0"
GOOGLE_CLOUD_PROJECT="your_gcp_project_id" # Required if USE_FIRESTORE="1" or GEMINI_USE_VERTEX="1"

# Safety Pipeline Configuration
HAZARD_CONFIRMATION_FRAMES="1"
HAZARD_CONFIRMATION_TIMEOUT_S="3.0"
EDGE_HAZARD_SUPPRESS_SECONDS="2.5"
SESSION_PERSIST_MIN_INTERVAL_S="1.5"

# System Configuration
APP_ENV="development" # set to "production" on deployed environments
LOG_LEVEL="INFO"
PUBLIC_HELP_BASE="https://your-frontend-domain.com/help"
WS_AUTH_MODE="shared_token" # shared_token | oidc | disabled
WS_AUTH_TOKEN="" # REQUIRED in production when WS_AUTH_MODE=shared_token
OIDC_ISSUER="" # REQUIRED when WS_AUTH_MODE=oidc (e.g. https://accounts.google.com)
OIDC_AUDIENCE="" # REQUIRED when WS_AUTH_MODE=oidc (comma-separated if multiple)
OIDC_JWKS_URL="" # optional override, auto-derived from OIDC_ISSUER when empty
OIDC_ALGORITHMS="RS256,ES256"
OIDC_LEEWAY_SECONDS="30"
CORS_ALLOW_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
ENABLE_DEV_ENDPOINTS="0" # Keep disabled in production
DEV_ENDPOINT_TOKEN="" # Required if ENABLE_DEV_ENDPOINTS="1" on shared environments
