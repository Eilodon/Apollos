# Frontend Environment Variables Template
# Copy this file to .env and fill in the values

# Production WebSocket Endpoint (MUST use wss:// for production)
# Example: wss://apollos-backend-xyz.run.app/ws
VITE_BACKEND_WS_BASE="wss://your-backend-domain.com/ws"

# Optional fallback shared token (legacy mode)
# VITE_WS_AUTH_TOKEN=""
# Optional legacy fallback: append token in query-string (less secure, default OFF)
VITE_WS_TOKEN_QUERY_FALLBACK="0"

# OIDC broker flow (token stays in memory/cookie, no localStorage persistence)
VITE_ENABLE_OIDC_BROKER="1"
VITE_AUTH_BROKER_BASE="/auth"
# Optional bootstrap ID token (in-memory only, do NOT commit real token)
# VITE_OIDC_BOOTSTRAP_TOKEN=""

# Optional: Custom Depth Model URL (if not hosted locally in public/models)
# VITE_DEPTH_MODEL_URL="/models/depth_anything_v2_small_fp16.tflite"
